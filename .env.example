AI_PROVIDER=openai
OPENAI_API_KEY=your_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Use these when AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Lightweight local pilot rate limits
CHAT_RATE_LIMIT_PER_MINUTE=12
FEEDBACK_RATE_LIMIT_PER_MINUTE=30
LAUNCH_AUDIT_RATE_LIMIT_PER_MINUTE=60
PROVIDER_TEST_RATE_LIMIT_PER_MINUTE=6

# Pilot-only admin protection for /admin and /api/admin/*
ADMIN_ACCESS_TOKEN=change_me_for_hosted_pilot

# Hosted Moodle origin allowed to frame the embedded assistant
MOODLE_ORIGIN=https://moodle.example.edu

# Future LTI 1.3 platform values from Moodle
LTI_PLATFORM_ISSUER=https://moodle.example.edu
LTI_CLIENT_ID=your_lti_client_id
LTI_DEPLOYMENT_ID=your_lti_deployment_id
LTI_PLATFORM_AUTH_URL=https://moodle.example.edu/mod/lti/auth.php
LTI_PLATFORM_TOKEN_URL=https://moodle.example.edu/mod/lti/token.php
LTI_PLATFORM_JWKS_URL=https://moodle.example.edu/mod/lti/certs.php

# Legacy review flag; Phase 2 also uses data/knowledge-base-review.json
KNOWLEDGE_BASE_REVIEWED=false
