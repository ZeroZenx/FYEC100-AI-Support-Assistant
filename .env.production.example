NEXT_PUBLIC_APP_BASE_URL=https://fyec100-assistant.example.edu

# Choose one provider: openai or ollama
AI_PROVIDER=openai

# OpenAI production settings
OPENAI_API_KEY=replace_with_secure_secret
OPENAI_MODEL=gpt-4o-mini

# Ollama production settings, if AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://ollama.internal:11434
OLLAMA_MODEL=llama3.1

# Lightweight pilot rate limits
CHAT_RATE_LIMIT_PER_MINUTE=12
FEEDBACK_RATE_LIMIT_PER_MINUTE=30
LAUNCH_AUDIT_RATE_LIMIT_PER_MINUTE=60
PROVIDER_TEST_RATE_LIMIT_PER_MINUTE=6

# Pilot-only admin protection for /admin and /api/admin/*
ADMIN_ACCESS_TOKEN=replace_with_secure_random_value

# Hosted Moodle origin allowed to frame the embedded assistant
MOODLE_ORIGIN=https://moodle.costaatt.edu.tt

# Future LTI 1.3 platform values from Moodle
LTI_PLATFORM_ISSUER=https://moodle.costaatt.edu.tt
LTI_CLIENT_ID=replace_with_moodle_client_id
LTI_DEPLOYMENT_ID=replace_with_moodle_deployment_id
LTI_PLATFORM_AUTH_URL=https://moodle.costaatt.edu.tt/mod/lti/auth.php
LTI_PLATFORM_TOKEN_URL=https://moodle.costaatt.edu.tt/mod/lti/token.php
LTI_PLATFORM_JWKS_URL=https://moodle.costaatt.edu.tt/mod/lti/certs.php

# Set to true only after lecturer/content-owner review
KNOWLEDGE_BASE_REVIEWED=false
